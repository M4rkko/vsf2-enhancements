VSF_NUXT_APP_ENV=development
VSF_NUXT_APP_PORT=3000
VSF_NUXT_APP_HOST=localhost

VSF_STORE_URL=http://localhost:3000

# API (middleware)
API_BASE_URL=http://localhost:3000/api/
API_SSR_BASE_URL=http://localhost:3000/api/

# Magento connection
VSF_MAGENTO_BASE_URL=https://m2.test
VSF_MAGENTO_GRAPHQL_URL=https://m2.test/graphql

# Checkout (keep disabled for now)
VSF_MAGENTO_EXTERNAL_CHECKOUT_ENABLED=false
VSF_MAGENTO_EXTERNAL_CHECKOUT_URL=https://m2.test
VSF_MAGENTO_EXTERNAL_CHECKOUT_SYNC_PATH=/vue/cart/sync

# Images (default, don’t touch)
NUXT_IMAGE_PROVIDER=ipx
NUXT_IMAGE_PROVIDER_BASE_URL=https://res-4.cloudinary.com/demo/image/upload/
NUXT_IMAGE_PROVIDER_DOMAIN=https://res-4.cloudinary.com

# Redis (disabled)
VSF_REDIS_ENABLED=false
VSF_REDIS_HOST=127.0.0.1
VSF_REDIS_PORT=6379
VSF_REDIS_KEY_PREFIX=
VSF_REDIS_CACHE_INVALIDATE_URL=/cache-invalidate

# Recaptcha (disabled)
VSF_RECAPTCHA_ENABLED=false
VSF_RECAPTCHA_SITE_KEY=
VSF_RECAPTCHA_SECRET_KEY=
VSF_RECAPTCHA_HIDE_BADGE=
VSF_RECAPTCHA_SIZE=invisible
VSF_RECAPTCHA_MIN_SCORE=0.5
VSF_RECAPTCHA_VERSION=3

# Cookies (leave empty for dev)
VSF_COOKIE_HTTP_ONLY=
VSF_COOKIE_SECURE=
VSF_COOKIE_SAME_SITE=
VSF_COOKIE_PATH=

# IMPORTANT: allow self-signed SSL (Docker Magento)
NODE_TLS_REJECT_UNAUTHORIZED=0


VSF_THEME_DEFAULT=default
VSF_THEME_TOGGLE=true
VSF_THEME_AVAILABLE=default,fire,ice